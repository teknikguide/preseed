#cloud-config
timezone: Europe/Stockholm

write_files:
  - path: /root/install-docker.sh
    permissions: '0700'
    content: |
      #!/bin/sh
      set -e

      # Docker Engine - installation enligt Dockers officiella instruktioner
      # https://docs.docker.com/engine/install/debian/

      apt-get update
      apt-get install -y ca-certificates curl
      install -m 0755 -d /etc/apt/keyrings
      curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc
      chmod a+r /etc/apt/keyrings/docker.asc

      cat > /etc/apt/sources.list.d/docker.sources <<EOF
      Types: deb
      URIs: https://download.docker.com/linux/debian
      Suites: $(. /etc/os-release && echo "$VERSION_CODENAME")
      Components: stable
      Architectures: $(dpkg --print-architecture)
      Signed-By: /etc/apt/keyrings/docker.asc
      EOF

      apt-get update
      apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

      # debadmin ska kunna köra docker utan sudo
      usermod -aG docker debadmin

      # Skapa dedikerad användare "docker" (engångslösenord, tvingas bytas vid
      # första inloggning, medlem i docker-gruppen - ingen sudo).
      # -g docker sätter docker-gruppen (skapad av docker-ce ovan) som
      # primärgrupp direkt - annars försöker useradd skapa en NY grupp med
      # samma namn som användaren och krockar med den redan existerande
      # docker-gruppen.
      id -u docker >/dev/null 2>&1 || useradd -m -s /bin/bash -g docker docker
      echo "docker:installtemp" | chpasswd
      passwd --expire docker

      systemctl enable --now docker
- path: /root/update-login-banner.sh
    permissions: '0700'
    content: |
      #!/bin/sh

      HOSTNAME="$(hostname)"
      IP_ADDRESS="$(hostname -I 2>/dev/null | awk '{print $1}')"

      {
        echo "=================================================="
        echo " Debian Server Installation Complete"
        echo "=================================================="
        echo
        echo "Hostname: ${HOSTNAME}"
        echo "IP address (DHCP): ${IP_ADDRESS:-Not assigned}"
        echo
        echo "Available users:"
        echo
        echo "  debadmin"
        echo "    - Member of the sudo group"
        echo "    - Management and administration account"
        echo
        echo "  docker"
        echo "    - Member of the docker group"
        echo "    - Docker and container account"
        echo
        echo "Initial password for both users: installtemp"
        echo "Password change is required at first login."
        echo
        echo "=================================================="
        echo
      } > /etc/issue

      systemctl restart getty@tty1.service || true
runcmd:
  - passwd --expire debadmin
  - /root/install-docker.sh
  - /root/update-login-banner.sh
  - touch /root/cloud-init-complete
runcmd:
  - passwd --expire debadmin
  - /root/install-docker.sh
  - /root/update-login-banner.sh
  - touch /root/cloud-init-complete
